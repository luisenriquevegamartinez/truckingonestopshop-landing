---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

const benefits = [
  { title: 'More Money Per Mile', desc: 'Our dispatchers negotiate rates 15–25% above what most owner-operators get on their own. We know the brokers, we know the lanes, and we fight for every dollar.' },
  { title: 'No Empty Miles', desc: 'Backhaul optimization and lane management mean your truck runs loaded, not empty. We plan round trips that maximize your time on the road.' },
  { title: 'Zero Paperwork Headaches', desc: 'Rate confirmations, BOLs, check calls, compliance filings — we handle all of it. You drive, we do the rest.' },
  { title: 'Your Dispatcher = Your Partner', desc: 'You\'re not talking to a call center. You have one dedicated dispatcher who knows your truck, your lanes, and your preferences by name.' },
  { title: 'Fast Payment', desc: 'Freight factoring partnerships and aggressive broker follow-up mean you get paid fast — not in 45-60 days.' },
  { title: 'Non-Forced Dispatch', desc: 'You approve every single load before it\'s booked. No pressure, no quotas. Your truck, your rules.' },
];
---

<Layout title="For Owner-Operators — Trucking One Stop Shop" description="TOSS helps owner-operators earn more, drive more, and stress less. Dedicated dispatch, rate negotiation, compliance and accounting — all in one place.">
  <Navbar />

  <PageHero
    title="For Owner-Operators"
    subtitle="Built for drivers who own their future"
    description="You bought your truck to be your own boss — not to spend your days chasing bad loads, fighting brokers, and drowning in paperwork. That's why TOSS exists."
  />

  <main class="bg-white">

    <!-- Partner criteria -->
    <section class="bg-gray-50 py-16">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-10 text-center text-3xl font-black text-gray-900">Requirements to partner with us</h2>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          {[
            { type: 'Dry Van', req: '1+ month active MC', color: 'border-green-400 bg-green-50', badge: 'bg-green-500' },
            { type: 'Flatbed / Reefer / Step Deck / Conestoga', req: '6+ months active MC', color: 'border-blue-400 bg-blue-50', badge: 'bg-blue-500' },
            { type: 'Hotshot', req: '6+ months active MC + 35ft trailer', color: 'border-orange-400 bg-orange-50', badge: 'bg-orange-500' },
            { type: 'Box Truck', req: '1+ year active MC + 1 DOT inspection', color: 'border-purple-400 bg-purple-50', badge: 'bg-purple-500' },
          ].map((c) => (
            <div class={`rounded-2xl border-2 p-5 ${c.color}`}>
              <span class={`mb-2 inline-block rounded px-2.5 py-1 text-xs font-bold text-white ${c.badge}`}>{c.type}</span>
              <p class="text-sm font-medium text-gray-700">{c.req}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-14 text-center">
          <h2 class="mb-3 text-4xl font-black text-gray-900 sm:text-5xl">What you get with TOSS</h2>
          <p class="mx-auto max-w-2xl text-lg text-gray-600">Everything that goes into running a profitable trucking operation — handled for you.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {benefits.map((b, i) => (
            <div class="flex gap-4 rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-orange-500 text-sm font-black text-white">
                {String(i + 1).padStart(2, '0')}
              </div>
              <div>
                <h3 class="mb-1.5 font-bold text-gray-900">{b.title}</h3>
                <p class="text-sm leading-relaxed text-gray-500">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="bg-gray-50 py-24">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="mb-12 text-center">
          <h2 class="mb-3 text-4xl font-black text-gray-900">How to get started</h2>
          <p class="text-lg text-gray-600">Three steps and you're running with a full dispatch team behind you.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-3">
          {[
            { step: '01', title: 'Submit the form', desc: 'Fill out the free setup form. A dispatcher will call you within 24 hours to discuss your truck type, lanes, and rate targets.' },
            { step: '02', title: 'Meet your dispatcher', desc: 'Your dedicated dispatcher is assigned and takes time to understand your preferences, home base, and the loads you want to run.' },
            { step: '03', title: 'Start earning more', desc: 'Your dispatcher finds and negotiates loads. You approve and drive. We handle everything else — all for 5% of gross revenue.' },
          ].map((s) => (
            <div class="rounded-2xl bg-white p-6 shadow-sm border border-gray-100 text-center">
              <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-orange-500 text-xl font-black text-white mx-auto">
                {s.step}
              </div>
              <h3 class="mb-2 text-base font-bold text-gray-900">{s.title}</h3>
              <p class="text-sm leading-relaxed text-gray-500">{s.desc}</p>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <a href="/contact-us" class="inline-block rounded-sm bg-orange-500 px-10 py-4 text-base font-bold text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-200">
            Get a free setup →
          </a>
        </div>
      </div>
    </section>

  </main>

  <CTABanner />
  <Footer />
</Layout>
