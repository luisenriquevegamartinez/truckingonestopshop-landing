---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: '10+', label: 'Years of experience' },
  { value: '1B+', label: 'Lbs dispatched' },
  { value: '$7.5k', label: 'Avg gross per load' },
  { value: '500+', label: 'Carriers served' },
];

const values = [
  { title: 'Transparency', desc: 'No hidden fees, no forced dispatch, no surprises. You always know what we\'re doing and why.' },
  { title: 'Partnership', desc: 'We treat every carrier as a long-term partner, not a transaction. Your success is our success.' },
  { title: 'Excellence', desc: 'Our dispatchers are trained professionals who stay current on market rates, lane trends, and compliance requirements.' },
  { title: 'Reliability', desc: 'We\'re available 24/7 because trucking doesn\'t follow a 9-to-5 schedule. When you need us, we\'re there.' },
];
---

<Layout title="About Us — Trucking One Stop Shop" description="Learn about Trucking One Stop Shop — our story, mission, values, and the team dedicated to helping owner-operators earn more and stress less.">
  <Navbar />

  <PageHero
    title="About Us"
    subtitle="Your success is our mission"
    description="Trucking One Stop Shop was founded with one goal: give independent carriers and small fleets access to the same level of professional dispatch and back-office support that large trucking companies have."
  />

  <main class="bg-white">

    <!-- Our story -->
    <section class="py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
          <div>
            <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">Our Story</p>
            <h2 class="mb-6 text-4xl font-black leading-tight text-gray-900 sm:text-5xl">
              We started where<br />you are now
            </h2>
            <p class="mb-5 text-lg leading-relaxed text-gray-600">
              Trucking One Stop Shop was built by people who understand the trucking industry from the ground up. We've seen first-hand how talented owner-operators struggle not because of bad driving, but because of bad loads, bad rates, and endless paperwork pulling them off the road.
            </p>
            <p class="mb-5 text-base leading-relaxed text-gray-600">
              Our dispatchers aren't just call-center agents reading from a script. They're logistics professionals who build real relationships with brokers, learn your lanes, and advocate for your rates every single day.
            </p>
            <p class="text-base leading-relaxed text-gray-600">
              Based in Miami, FL, we serve carriers across the United States — from solo Dry Van operators just starting out to multi-truck Flatbed and Reefer fleets running dedicated lanes coast to coast.
            </p>
          </div>
          <div class="overflow-hidden rounded-2xl bg-gray-100 shadow-sm">
            <img
              src={`${(import.meta.env.BASE_URL + '/').replace('//', '/')}images/about-truck.png`}
              alt="TOSS trucking fleet"
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="border-y border-gray-200 bg-gray-50 py-14">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
          {stats.map((s, i) => (
            <div class={`text-center ${i < 3 ? 'lg:border-r lg:border-gray-200' : ''}`}>
              <p class="text-4xl font-black text-orange-500 lg:text-5xl">{s.value}</p>
              <p class="mt-2 text-sm font-medium text-gray-500">{s.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="mb-14 text-center">
          <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">Our Values</p>
          <h2 class="text-4xl font-black text-gray-900 sm:text-5xl">What we stand for</h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {values.map((v) => (
            <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm text-center">
              <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-orange-50 mx-auto">
                <svg class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
              </div>
              <h3 class="mb-2 text-base font-bold text-gray-900">{v.title}</h3>
              <p class="text-sm leading-relaxed text-gray-500">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <CTABanner />
  <Footer />
</Layout>
