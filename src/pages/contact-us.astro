---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact Us — Trucking One Stop Shop" description="Get in touch with Trucking One Stop Shop. Call, email, or fill out the form and a dispatcher will reach out within 24 hours.">
  <Navbar />

  <PageHero
    title="Contact Us"
    subtitle="We're here to help"
    description="Fill out the form below or call us directly. A dedicated dispatcher will reach out within 24 hours."
  />

  <main class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-[1fr_420px] lg:items-start">

        <!-- Contact info -->
        <div>
          <h2 class="mb-8 text-3xl font-black text-gray-900">Get in touch</h2>

          <div class="space-y-6">
            {[
              {
                icon: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z',
                label: 'Phone',
                value: '+1 888-777-1839',
                href: 'tel:+18887771839',
              },
              {
                icon: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
                label: 'Email',
                value: 'info@truckingonestopshop.net',
                href: 'mailto:info@truckingonestopshop.net',
              },
              {
                icon: 'M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z',
                label: 'Address',
                value: '1065 SW 8th St, Miami, FL 33130',
                href: null,
              },
              {
                icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
                label: 'Hours',
                value: 'Monday–Friday: 7AM – 5PM EST\nSaturday–Sunday: Closed',
                href: null,
              },
            ].map((item) => (
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-orange-50">
                  <svg class="h-6 w-6 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={item.icon}/>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gray-400">{item.label}</p>
                  {item.href ? (
                    <a href={item.href} class="text-base font-semibold text-gray-900 hover:text-orange-500 transition-colors">
                      {item.value}
                    </a>
                  ) : (
                    <p class="whitespace-pre-line text-base font-semibold text-gray-900">{item.value}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Contact form -->
        <div class="rounded-2xl border border-gray-100 bg-gray-50 p-8 shadow-sm">
          <h3 class="mb-5 text-xl font-black text-gray-900">Send us a message</h3>
          <form class="space-y-4" action="mailto:info@truckingonestopshop.net" method="POST">
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">Your name</label>
              <input type="text" name="name" placeholder="Your name" required
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20"/>
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">Your email</label>
              <input type="email" name="email" placeholder="Your email" required
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20"/>
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">Your phone</label>
              <input type="tel" name="phone" placeholder="Your phone" required
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20"/>
            </div>
            <div>
              <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">Message</label>
              <textarea name="message" rows="4" placeholder="How can we help you?"
                class="w-full rounded-lg border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:border-orange-500 focus:outline-none focus:ring-2 focus:ring-orange-500/20 resize-none"></textarea>
            </div>
            <div class="flex items-start gap-3">
              <input type="checkbox" id="consent-contact" name="consent" required class="mt-0.5 h-4 w-4 shrink-0 accent-orange-500"/>
              <label for="consent-contact" class="text-xs leading-relaxed text-gray-500">
                I agree to receive emails and SMS marketing messages from Trucking One Stop Shop. Message rates may apply.
              </label>
            </div>
            <button type="submit"
              class="w-full rounded-sm bg-orange-500 px-6 py-4 text-sm font-bold text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-200">
              Send message →
            </button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
