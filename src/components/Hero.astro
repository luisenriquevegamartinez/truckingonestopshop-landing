---
const base = (import.meta.env.BASE_URL + '/').replace('//', '/');
---

<section class="relative min-h-screen overflow-hidden bg-white pt-20">

  <!-- ─── RIGHT: frame shape + video (absolute, right half) ─── -->
  <div class="absolute inset-y-0 right-0 hidden w-[52%] overflow-hidden lg:block">
    <!-- Curved frame shape as background of the right panel -->
    <img
      src={`${base}images/hero-frame.svg`}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full"
      style="object-fit: fill;"
    />
    <!-- Truck video: autoplay, muted, loop — matches logitydispatch.com hero -->
    <video
      src={`${base}videos/hero-truck.mp4`}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="relative h-full w-full object-cover"
    ></video>
  </div>

  <!-- Mobile: video as full-width block above content -->
  <div class="relative aspect-video w-full overflow-hidden lg:hidden">
    <video
      src={`${base}videos/hero-truck.mp4`}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      class="h-full w-full object-cover"
    ></video>
  </div>

  <!-- ─── Content layer ─── -->
  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid min-h-[calc(100vh-80px)] items-center py-12 lg:grid-cols-2 lg:py-20">

      <!-- LEFT: Headline + form -->
      <div class="pr-0 lg:pr-12">

        <!-- Stars using the real SVG from logitydispatch -->
        <div class="mb-6 flex items-center gap-3">
          <img src={`${base}images/hero-graphic.svg`} alt="5 stars" class="h-5 w-auto" loading="eager" />
          <span class="text-sm font-semibold text-gray-700">
            Rated 4.9+ stars by 500+ carriers
          </span>
        </div>

        <!-- Headline — "truck" in brand orange -->
        <h1
          class="mb-5 text-5xl font-black leading-[1.06] tracking-tight text-gray-900
                 sm:text-6xl xl:text-[68px]"
        >
          Automate your<br />
          <span class="text-orange-500">truck</span> business
        </h1>

        <p class="mb-8 max-w-md text-lg leading-relaxed text-gray-600">
          Reliable truck dispatch services for owner-operators and fleets —
          maximize profits, minimize stress, drive success.
        </p>

        <!-- Lead form (same position as logitydispatch — below headline, left column) -->
        <form
          class="space-y-3 rounded-2xl border border-gray-100 bg-white p-6 shadow-lg"
          action="mailto:info@truckingonestopshop.net"
          method="POST"
        >
          <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">
              Your name
            </label>
            <input
              type="text"
              name="name"
              placeholder="Your name"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-gray-900
                     placeholder-gray-400 transition focus:border-orange-500 focus:outline-none
                     focus:ring-2 focus:ring-orange-500/20"
            />
          </div>

          <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">
              Your email
            </label>
            <input
              type="email"
              name="email"
              placeholder="Your email"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-gray-900
                     placeholder-gray-400 transition focus:border-orange-500 focus:outline-none
                     focus:ring-2 focus:ring-orange-500/20"
            />
          </div>

          <div>
            <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-gray-500">
              Your phone
            </label>
            <input
              type="tel"
              name="phone"
              placeholder="Your phone"
              required
              class="w-full rounded-lg border border-gray-300 px-4 py-3 text-sm text-gray-900
                     placeholder-gray-400 transition focus:border-orange-500 focus:outline-none
                     focus:ring-2 focus:ring-orange-500/20"
            />
          </div>

          <div class="flex items-start gap-3 pt-1">
            <input
              type="checkbox"
              id="consent-hero"
              name="consent"
              required
              class="mt-0.5 h-4 w-4 shrink-0 accent-orange-500 rounded"
            />
            <label for="consent-hero" class="text-xs leading-relaxed text-gray-500">
              I agree to receive emails and SMS marketing messages from
              Trucking One Stop Shop. Message rates may apply.
            </label>
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-orange-500 px-6 py-4 text-sm font-bold text-white
                   transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-200
                   active:scale-[0.99]"
          >
            Get a free setup →
          </button>
        </form>

        <p class="mt-3 text-xs text-gray-400">
          No contracts · No hidden fees · Cancel anytime
        </p>
      </div>

      <!-- Right column spacer on desktop (video is absolute) -->
      <div class="hidden lg:block" aria-hidden="true"></div>

    </div>
  </div>
</section>
