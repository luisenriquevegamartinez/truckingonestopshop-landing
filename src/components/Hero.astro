---
---

<section class="relative min-h-screen overflow-hidden bg-slate-900 pt-24">
  <!-- Background decorations -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div
      class="absolute -top-40 -right-40 h-[500px] w-[500px] rounded-full bg-orange-500/8 blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/3 -left-40 h-[400px] w-[400px] rounded-full bg-blue-600/8 blur-3xl"
    >
    </div>
    <!-- Grid pattern -->
    <div
      class="absolute inset-0 opacity-[0.03]"
      style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid gap-16 lg:grid-cols-2 lg:items-center">
      <!-- Left: Content + Form -->
      <div>
        <!-- Badge -->
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-orange-500/30 bg-orange-500/10 px-4 py-2"
        >
          <span class="h-2 w-2 animate-pulse rounded-full bg-orange-500"></span>
          <span class="text-sm font-medium text-orange-400"
            >Trusted by 500+ Owner-Operators across the USA</span
          >
        </div>

        <!-- Headline -->
        <h1
          class="mb-6 text-5xl font-black leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl"
        >
          Automate Your
          <span class="text-orange-500"> Truck</span>
          <br />Business
        </h1>

        <p class="mb-8 max-w-lg text-lg leading-relaxed text-slate-400">
          Dedicated dispatchers, aggressive rate negotiation, DOT compliance, and
          accounting — everything your trucking business needs, under one roof.
        </p>

        <!-- Trust badges -->
        <div class="mb-10 flex flex-wrap gap-5">
          {
            [
              '24/7 Dispatcher Support',
              'Starting at 5% Commission',
              'No Hidden Fees',
            ].map((badge) => (
              <div class="flex items-center gap-2 text-sm text-slate-400">
                <svg
                  class="h-5 w-5 shrink-0 text-orange-500"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"
                  />
                </svg>
                {badge}
              </div>
            ))
          }
        </div>

        <!-- Lead form -->
        <div
          id="contact"
          class="rounded-2xl border border-slate-700/50 bg-slate-800/60 p-6 backdrop-blur-sm"
        >
          <h3 class="mb-1 text-lg font-bold text-white">Get Your Free Setup</h3>
          <p class="mb-5 text-sm text-slate-400">
            No commitment. A dedicated dispatcher will contact you within 24 hours.
          </p>
          <form
            class="space-y-4"
            action="mailto:info@truckingonestopshop.net"
            method="POST"
          >
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-300"
                  >Full Name</label
                >
                <input
                  type="text"
                  name="name"
                  placeholder="John Smith"
                  required
                  class="w-full rounded-lg border border-slate-600 bg-slate-700/50 px-4 py-3 text-sm text-white placeholder-slate-500 transition-colors focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
                />
              </div>
              <div>
                <label class="mb-1.5 block text-sm font-medium text-slate-300"
                  >Phone Number</label
                >
                <input
                  type="tel"
                  name="phone"
                  placeholder="+1 (555) 000-0000"
                  required
                  class="w-full rounded-lg border border-slate-600 bg-slate-700/50 px-4 py-3 text-sm text-white placeholder-slate-500 transition-colors focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
                />
              </div>
            </div>
            <div>
              <label class="mb-1.5 block text-sm font-medium text-slate-300"
                >Email Address</label
              >
              <input
                type="email"
                name="email"
                placeholder="john@example.com"
                required
                class="w-full rounded-lg border border-slate-600 bg-slate-700/50 px-4 py-3 text-sm text-white placeholder-slate-500 transition-colors focus:border-orange-500 focus:outline-none focus:ring-1 focus:ring-orange-500"
              />
            </div>
            <button
              type="submit"
              class="w-full rounded-lg bg-orange-500 px-6 py-4 text-base font-bold text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/25 active:scale-[0.99]"
            >
              Get Free Setup — No Commitment
            </button>
          </form>
          <p class="mt-3 text-center text-xs text-slate-500">
            We respect your privacy. Your information is never shared with third parties.
          </p>
        </div>
      </div>

      <!-- Right: Dashboard visual -->
      <div class="relative hidden lg:block">
        <!-- Main card -->
        <div
          class="rounded-2xl border border-slate-700/50 bg-slate-800/80 p-8 shadow-2xl backdrop-blur-sm"
        >
          <!-- Dispatcher header -->
          <div class="mb-6 flex items-center justify-between">
            <div>
              <p class="text-xs text-slate-400">Your Dedicated Dispatcher</p>
              <p class="text-lg font-bold text-white">Maria Rodriguez</p>
            </div>
            <div
              class="flex h-12 w-12 items-center justify-center rounded-full bg-orange-500 text-white font-bold text-lg"
            >
              MR
            </div>
          </div>

          <!-- Active load -->
          <div
            class="mb-6 rounded-xl border border-orange-500/20 bg-orange-500/10 p-4"
          >
            <div class="mb-3 flex items-center gap-2">
              <span class="h-2 w-2 animate-pulse rounded-full bg-green-400"></span>
              <span class="text-xs font-semibold tracking-wider text-green-400"
                >ACTIVE LOAD</span
              >
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-xs text-slate-400">Origin</p>
                <p class="font-semibold text-white">Chicago, IL</p>
              </div>
              <div>
                <p class="text-xs text-slate-400">Destination</p>
                <p class="font-semibold text-white">Miami, FL</p>
              </div>
              <div>
                <p class="text-xs text-slate-400">Negotiated Rate</p>
                <p class="text-lg font-black text-orange-400">$4,850</p>
              </div>
              <div>
                <p class="text-xs text-slate-400">Distance</p>
                <p class="font-semibold text-white">1,378 mi</p>
              </div>
            </div>
          </div>

          <!-- Weekly earnings chart -->
          <div class="mb-6">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-sm font-semibold text-white">Weekly Earnings</p>
              <span
                class="rounded-full bg-green-500/20 px-2.5 py-0.5 text-xs font-medium text-green-400"
                >+18% vs last week</span
              >
            </div>
            <div class="flex h-16 items-end gap-1.5">
              {
                [40, 65, 45, 80, 60, 95, 75].map((h) => (
                  <div
                    class="flex-1 rounded-sm bg-orange-500/40 transition-all"
                    style={`height: ${h}%`}
                  />
                ))
              }
            </div>
            <div class="mt-2 flex justify-between text-xs text-slate-500">
              {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((d) => (
                <span>{d}</span>
              ))}
            </div>
          </div>

          <!-- Mini stats -->
          <div class="grid grid-cols-3 gap-3">
            <div class="rounded-xl bg-slate-700/60 p-3 text-center">
              <p class="text-xl font-black text-orange-400">$7.5k</p>
              <p class="text-xs text-slate-400">Avg/Load</p>
            </div>
            <div class="rounded-xl bg-slate-700/60 p-3 text-center">
              <p class="text-xl font-black text-white">12</p>
              <p class="text-xs text-slate-400">Loads/Mo</p>
            </div>
            <div class="rounded-xl bg-slate-700/60 p-3 text-center">
              <p class="text-xl font-black text-green-400">5%</p>
              <p class="text-xs text-slate-400">Commission</p>
            </div>
          </div>
        </div>

        <!-- Floating notification: New Load -->
        <div
          class="absolute -top-5 -right-5 rounded-xl border border-slate-700/60 bg-slate-800 px-4 py-3 shadow-xl"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-green-500/20"
            >
              <svg
                class="h-4 w-4 text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-white">New Load Secured!</p>
              <p class="text-xs text-slate-400">$2,100 · DAL → NYC</p>
            </div>
          </div>
        </div>

        <!-- Floating notification: Rate -->
        <div
          class="absolute -bottom-5 -left-5 rounded-xl border border-slate-700/60 bg-slate-800 px-4 py-3 shadow-xl"
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-blue-500/20"
            >
              <svg
                class="h-4 w-4 text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                ></path>
              </svg>
            </div>
            <div>
              <p class="text-xs font-semibold text-white">Rate Negotiated</p>
              <p class="text-xs text-slate-400">+$350 above market avg</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
