---
const companyLinks = [
  { label: 'About Us', href: '#about' },
  { label: 'Contact Us', href: '#setup' },
  { label: 'Services & Pricing', href: '#services' },
  { label: 'Truck Types', href: '#trucks' },
  { label: 'Owner-operators', href: '#about' },
];

const serviceLinks = [
  { label: 'Dispatching — Trucking Services', href: '#services' },
  { label: 'Document Dispatch Services', href: '#services' },
  { label: 'Trucking Paperwork Services', href: '#services' },
  { label: 'Trucking Invoice Service', href: '#services' },
  { label: 'Truckers Accounting', href: '#services' },
  { label: 'Company Formation Services', href: '#services' },
  { label: 'Freight Rate Negotiation', href: '#services' },
  { label: 'Freight Factoring', href: '#services' },
  { label: 'DOT Compliance Services', href: '#services' },
];

const faqLinks = [
  { label: 'FAQ', href: '#faq' },
  { label: 'How to start', href: '#setup' },
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms of Service', href: '#' },
];

const socials = [
  { label: 'Facebook',  href: '#', icon: '/images/icon-dispatch.svg' },
];
---

<footer class="bg-gray-900 pt-16 pb-8 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <div class="mb-12 grid gap-10 md:grid-cols-2 lg:grid-cols-4">

      <!-- Brand + contact -->
      <div class="lg:col-span-1">
        <a href="/" class="mb-5 inline-block">
          <img
            src="https://cdn.prod.website-files.com/68dc088d78e9540e9d74949f/68e4d2ccfc8139bd14c4b59f_Con%20slogan%20(1).svg"
            alt="Trucking One Stop Shop"
            class="h-10 w-auto brightness-0 invert"
            loading="lazy"
            onerror="this.style.display='none';this.nextElementSibling.style.display='block';"
          />
          <span style="display:none" class="font-black text-white text-lg">TOSS</span>
        </a>

        <div class="mb-5 space-y-2.5 text-sm text-gray-400">
          <a href="tel:+18887771839" class="flex items-center gap-2 hover:text-orange-400 transition-colors">
            <svg class="h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
            +1 888-777-1839
          </a>
          <a href="mailto:info@truckingonestopshop.net" class="flex items-center gap-2 hover:text-orange-400 transition-colors">
            <svg class="h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            info@truckingonestopshop.net
          </a>
          <div class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
            <span>1065 SW 8th St, Miami, FL 33130</span>
          </div>
          <div class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            <span>Monday–Friday: 7AM – 5PM<br/>Saturday–Sunday: Closed</span>
          </div>
        </div>

        <!-- Social icons -->
        <div class="flex gap-3">
          {[
            { label: 'Facebook', path: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z' },
            { label: 'LinkedIn', path: 'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z' },
            { label: 'Instagram', path: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z' },
          ].map((s) => (
            <a href="#" aria-label={s.label}
              class="flex h-9 w-9 items-center justify-center rounded-full bg-gray-800 text-gray-400 transition-colors hover:bg-orange-500 hover:text-white">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d={s.path}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Company -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">Company</h4>
        <ul class="space-y-2.5">
          {companyLinks.map((l) => (
            <li><a href={l.href} class="text-sm text-gray-300 hover:text-orange-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">Services</h4>
        <ul class="space-y-2.5">
          {serviceLinks.map((l) => (
            <li><a href={l.href} class="text-sm text-gray-300 hover:text-orange-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- FAQ -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">FAQ</h4>
        <ul class="space-y-2.5">
          {faqLinks.map((l) => (
            <li><a href={l.href} class="text-sm text-gray-300 hover:text-orange-400 transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col items-center gap-2 sm:flex-row sm:justify-between">
      <p class="text-sm text-gray-500">Copyright &copy; {new Date().getFullYear()} Trucking One Stop Shop. All rights reserved.</p>
      <div class="flex gap-4 text-xs text-gray-500">
        <a href="#" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-gray-300 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
