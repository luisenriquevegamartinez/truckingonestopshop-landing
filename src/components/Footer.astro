---
const services = [
  { label: 'Dispatch Services', href: '#services' },
  { label: 'Rate Negotiation', href: '#services' },
  { label: 'Trucking Accounting', href: '#services' },
  { label: 'DOT Compliance', href: '#services' },
  { label: 'Freight Factoring', href: '#services' },
  { label: 'Invoice Processing', href: '#services' },
];

const trucks = [
  { label: 'Dry Van Dispatch', href: '#trucks' },
  { label: 'Flatbed Dispatch', href: '#trucks' },
  { label: 'Reefer Dispatch', href: '#trucks' },
  { label: 'Step Deck Dispatch', href: '#trucks' },
  { label: 'Hotshot Dispatch', href: '#trucks' },
  { label: 'Conestoga Dispatch', href: '#trucks' },
];

const company = [
  { label: 'About Us', href: '#about' },
  { label: 'Contact', href: '#contact' },
  { label: 'Privacy Policy', href: '#' },
  { label: 'Terms & Conditions', href: '#' },
];
---

<footer class="bg-gray-900 pt-16 pb-8 text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Top grid -->
    <div class="mb-12 grid gap-10 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="mb-5 inline-block">
          <img
            src="https://cdn.prod.website-files.com/68dc088d78e9540e9d74949f/68e4d2ccfc8139bd14c4b59f_Con%20slogan%20(1).svg"
            alt="Trucking One Stop Shop"
            class="h-11 w-auto brightness-0 invert"
            loading="lazy"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
          />
          <span style="display:none" class="text-lg font-black text-white">TOSS</span>
        </a>
        <p class="mb-5 max-w-xs text-sm leading-relaxed text-gray-400">
          Empowering carriers with dedicated dispatch, compliance, and accounting
          services. Your success is our mission.
        </p>
        <!-- Contact info -->
        <div class="space-y-2.5 text-sm text-gray-400">
          <a href="tel:+18887771839" class="flex items-center gap-2 hover:text-orange-400 transition-colors">
            <svg class="h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            +1 888-777-1839
          </a>
          <a href="mailto:info@truckingonestopshop.net" class="flex items-center gap-2 hover:text-orange-400 transition-colors">
            <svg class="h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            info@truckingonestopshop.net
          </a>
          <div class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
            </svg>
            <span>1065 SW 8th St, Miami, FL 33130</span>
          </div>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">Services</h4>
        <ul class="space-y-2.5">
          {services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-300 transition-colors hover:text-orange-400">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Trucks -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">Truck Types</h4>
        <ul class="space-y-2.5">
          {trucks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-300 transition-colors hover:text-orange-400">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-wider text-gray-400">Company</h4>
        <ul class="mb-6 space-y-2.5">
          {company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-300 transition-colors hover:text-orange-400">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
        <a
          href="#contact"
          class="inline-block rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-orange-600"
        >
          Get Free Setup
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 pt-8 text-center text-sm text-gray-500">
      <p>&copy; {new Date().getFullYear()} Trucking One Stop Shop. All rights reserved.</p>
    </div>
  </div>
</footer>
