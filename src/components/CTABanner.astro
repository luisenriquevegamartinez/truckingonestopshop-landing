---
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-center">

      <!-- Left: Text -->
      <div>
        <h2 class="mb-5 text-4xl font-black leading-tight text-gray-900 sm:text-5xl">
          Don't drive empty.<br />
          <span class="text-orange-500">Drive with TOSS!</span>
        </h2>
        <p class="mb-8 text-lg leading-relaxed text-gray-600">
          You didn't buy a truck to chase bad loads or sit empty. Our dedicated dispatchers help you stay loaded, earn more per mile, and eliminate the stress of running your own back office.
        </p>

        <ul class="mb-10 space-y-4">
          {[
            'Full-Service Dispatch Support',
            'Efficient Route Planning',
            'Non-forced dispatch — you approve every load',
          ].map((item) => (
            <li class="flex items-center gap-3 text-base font-medium text-gray-700">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-orange-500">
                <svg class="h-3.5 w-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              {item}
            </li>
          ))}
        </ul>

        <div class="flex flex-col gap-3 sm:flex-row">
          <a href="#setup" class="rounded-lg bg-orange-500 px-8 py-4 text-center text-base font-bold text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-200">
            Send Request
          </a>
          <a href="tel:+18887771839" class="flex items-center justify-center gap-2 rounded-lg border-2 border-gray-300 px-8 py-4 text-base font-bold text-gray-700 transition-all hover:border-orange-400 hover:text-orange-500">
            +1 888-777-1839
          </a>
        </div>
      </div>

      <!-- Right: Truck illustration -->
      <div class="flex items-center justify-center">
        <img
          src="/images/cta-truck.png"
          alt="Trucking One Stop Shop dispatch"
          class="w-full max-w-lg object-contain"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
