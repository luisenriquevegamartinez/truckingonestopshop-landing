<section class="relative overflow-hidden bg-orange-500 py-20">
  <!-- Background pattern -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 40px 40px;"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-orange-100">
      Ready to Grow Your Business?
    </p>
    <h2 class="mb-6 text-4xl font-black text-white sm:text-5xl lg:text-6xl">
      Your Success Is Our Mission
    </h2>
    <p class="mb-10 mx-auto max-w-xl text-lg text-orange-100">
      Join 500+ owner-operators and fleet owners who've trusted Trucking One Stop
      Shop to handle their dispatch, compliance, and accounting.
    </p>
    <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
      <a
        href="#contact"
        class="rounded-xl bg-white px-8 py-4 text-base font-bold text-orange-600 transition-all hover:bg-orange-50 hover:shadow-lg"
      >
        Get Free Setup Now
      </a>
      <a
        href="tel:+18887771839"
        class="rounded-xl border-2 border-white/40 bg-white/10 px-8 py-4 text-base font-bold text-white backdrop-blur-sm transition-all hover:bg-white/20"
      >
        Call +1 888-777-1839
      </a>
    </div>
    <p class="mt-6 text-sm text-orange-200">
      No contracts. No setup fees. Cancel anytime.
    </p>
  </div>
</section>
