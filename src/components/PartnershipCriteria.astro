---
const criteria = [
  {
    type: 'Hotshot',
    color: 'border-orange-400 bg-orange-50',
    badge: 'bg-orange-500',
    reqs: ['6+ months active MC', '35ft+ trailer minimum'],
  },
  {
    type: 'Box Truck',
    color: 'border-blue-400 bg-blue-50',
    badge: 'bg-blue-500',
    reqs: ['1+ year active MC', '1 DOT inspection on record'],
  },
  {
    type: 'Dry Van',
    color: 'border-green-400 bg-green-50',
    badge: 'bg-green-500',
    reqs: ['1+ month active MC'],
  },
  {
    type: 'Reefers / Flatbeds / Stepdecks',
    color: 'border-purple-400 bg-purple-50',
    badge: 'bg-purple-500',
    reqs: ['6+ months active MC'],
  },
];
---

<section class="bg-white py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="mb-10 text-center text-2xl font-black text-gray-900 sm:text-3xl">
      KEY criteria of partnering with us:
    </h2>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {criteria.map((c) => (
        <div class={`rounded-2xl border-2 p-6 ${c.color}`}>
          <span class={`mb-3 inline-block rounded-lg px-3 py-1 text-xs font-bold text-white ${c.badge}`}>
            {c.type}
          </span>
          <ul class="space-y-2">
            {c.reqs.map((r) => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                {r}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
