---
const reviews = [
  {
    avatar: 'https://lh3.googleusercontent.com/a/ACg8ocKhoDg9A9TMGWR032fAQHb7pC4jjGMCD3fdjzSiRzaWj4a7iQ=s128-c0x00000000-cc-rp-mo-ba3',
    name: 'William R. Kennedy',
    date: '1 year ago',
    text: 'This dispatch company is by far the best I\'ve been associated with in my 50 years of being an independent owner operator. Respect is the number one thing I\'ve noticed between dispatch and truckers. I\'ve been very pleased with the quality of loads and the communication.',
  },
  {
    avatar: 'https://lh3.googleusercontent.com/a-/ALV-UjWN5oQRmORgnTZINvn95cO9OzhvDkFrG61r0HgBiPHu0l4H3og=s128-c0x00000000-cc-rp-mo',
    name: 'Matthew Smith',
    date: '1 year ago',
    text: 'Great experience! The team is professional and responsive. My dispatcher got me loaded within hours of signing up and the rate was well above what I was getting on my own.',
  },
  {
    avatar: 'https://lh3.googleusercontent.com/a/ACg8ocI7i6bqF3xCQqlir-GgVV3iGDn-yEk_b6XgeqHHUsrdGhFOnQ=s128-c0x00000000-cc-rp-mo',
    name: 'Eddie Cole',
    date: '2 years ago',
    text: 'In my 30 years as an owner-operator I\'ve worked with a lot of dispatch services. TOSS is in a different league. My dispatcher negotiates rates I never could on my own and handles all the paperwork flawlessly.',
  },
  {
    avatar: 'https://lh3.googleusercontent.com/a/ACg8ocKC3Y8nfHusW8BB3ixUgfk0bGNPnC2SFq1noa6mZmrXBu9r5w=s128-c0x00000000-cc-rp-mo',
    name: 'Harjot Kaur',
    date: '2 years ago',
    text: 'I\'ve been partnered with TOSS for over 3 years. The load quality is consistently excellent and they handle all my compliance paperwork without me having to ask twice. Wouldn\'t go anywhere else.',
  },
  {
    avatar: 'https://lh3.googleusercontent.com/a-/ALV-UjWl6xuYc_lojQ4pK1DlLd1xM7CXWmL4MLuETYZNil7ENLY50ocTcg=s128-c0x00000000-cc-rp-mo-ba3',
    name: 'C T',
    date: '2 years ago',
    text: 'Trucking One Stop Shop is hands down 5 stars!! Best dispatch experience I\'ve had. They treat you like a partner, not just another truck. Highly recommend to any owner-operator.',
  },
  {
    avatar: 'https://lh3.googleusercontent.com/a/ACg8ocJcGwBjYslY_-W9RyU6QgxnxbVASI_ftRBbqzy7_28ZFzyHeA=s128-c0x00000000-cc-rp-mo',
    name: 'Troy Martin',
    date: '2 years ago',
    text: 'Switched from my previous dispatch 6 months ago and my revenue is up 25%. My dispatcher knows exactly what I need and always delivers. The accounting support is a huge bonus.',
  },
];
---

<section class="bg-gray-50 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-12 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">Reviews</p>
      <h2 class="mb-4 text-4xl font-black text-gray-900 sm:text-5xl">Trusted by our customers</h2>

      <!-- Overall rating display -->
      <div class="mx-auto mt-6 inline-flex items-center gap-4 rounded-xl border border-gray-200 bg-white px-6 py-4 shadow-sm">
        <div>
          <p class="text-3xl font-black text-gray-900">4.9</p>
          <div class="flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
              </svg>
            ))}
          </div>
        </div>
        <div class="border-l border-gray-200 pl-4 text-left">
          <p class="text-sm font-semibold text-gray-700">Based on 500+ reviews</p>
          <p class="text-xs text-gray-400">powered by Google</p>
        </div>
      </div>
    </div>

    <!-- Reviews grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {reviews.map((r) => (
        <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
          <div class="mb-3 flex gap-0.5">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z"/>
              </svg>
            ))}
          </div>
          <p class="mb-5 text-sm leading-relaxed text-gray-600">"{r.text}"</p>
          <div class="flex items-center gap-3">
            <img src={r.avatar} alt={r.name} class="h-10 w-10 rounded-full object-cover"
              loading="lazy" onerror="this.src='';this.className='h-10 w-10 rounded-full bg-orange-100 flex items-center justify-center text-orange-500 font-bold text-sm'" />
            <div>
              <p class="text-sm font-bold text-gray-900">{r.name}</p>
              <p class="text-xs text-gray-400">{r.date}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
