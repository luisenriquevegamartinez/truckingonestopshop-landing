---
const base = (import.meta.env.BASE_URL + '/').replace('//', '/');
const trucks = [
  { type: 'Hotshot',          commission: '7%', img: `${base}images/truck-hotshot.png`,   href: '#contact' },
  { type: 'Flatbed',          commission: '5%', img: `${base}images/truck-flatbed.png`,   href: '#contact' },
  { type: 'Reefer',           commission: '5%', img: `${base}images/truck-reefer.png`,    href: '#contact' },
  { type: 'Step Deck',        commission: '5%', img: `${base}images/truck-stepdeck.png`,  href: '#contact' },
  { type: 'Dry Van',          commission: '5%', img: `${base}images/truck-dryvan.png`,    href: '#contact' },
  { type: 'Conestoga Trailer',commission: '5%', img: `${base}images/truck-conestoga.png`, href: '#contact' },
];
---

<section id="trucks" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-14 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">What We Dispatch</p>
      <h2 class="mb-4 text-4xl font-black text-gray-900 sm:text-5xl">Choose your truck type</h2>
      <p class="mx-auto max-w-2xl text-lg text-gray-600">
        Your trucks will stay loaded, your routes optimized, and your paperwork handled — no matter what you drive.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {trucks.map((t) => (
        <div class="group overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm transition-all hover:border-orange-300 hover:shadow-md">
          <!-- Truck image -->
          <div class="flex h-48 items-center justify-center overflow-hidden bg-gray-50 p-4">
            <img
              src={t.img}
              alt={`${t.type} dispatch`}
              class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <!-- Card content -->
          <div class="p-6">
            <div class="mb-4 flex items-center justify-between">
              <h3 class="text-xl font-black text-gray-900">{t.type}</h3>
              <div class="text-right">
                <span class="text-2xl font-black text-orange-500">{t.commission}</span>
                <p class="text-xs text-gray-400">commission</p>
              </div>
            </div>
            <a
              href="#setup"
              class="block w-full rounded-lg bg-orange-500 py-3 text-center text-sm font-bold text-white transition-all hover:bg-orange-600"
            >
              Get a free setup
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
