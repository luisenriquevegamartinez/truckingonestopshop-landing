---
const advantages = [
  {
    title: 'Efficient Route Planning',
    desc: 'We reduce empty miles and maximize your loaded miles by securing backhauls and optimizing round-trip routes in your preferred lanes.',
  },
  {
    title: 'Dedicated Runs & Broker Partnerships',
    desc: 'Direct relationships with the largest freight brokers — Echo, Coyote, CH Robinson, and 100s more — means priority access to the best loads.',
  },
  {
    title: 'Automation & AI-Driven Tools',
    desc: 'We leverage cutting-edge dispatch automation tools to find loads faster, track market rate trends, and keep your truck moving 24/7.',
  },
  {
    title: 'Freight Rate Forecasting',
    desc: 'Real-time market insights and rate forecasting help your dispatcher time bookings for maximum profitability on every lane.',
  },
  {
    title: 'End-to-End Personalized Support',
    desc: 'Your dispatcher is your dedicated partner — not a call center. They know your truck, your lanes, and your preferences inside out.',
  },
  {
    title: '24/7 On-Road Support',
    desc: 'Load issue at midnight? Breakdown on the road? We\'re always available. Your dispatcher picks up when you need them most.',
  },
];
---

<section class="bg-gray-50 py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-14 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">Why TOSS</p>
      <h2 class="mb-4 text-4xl font-black text-gray-900 sm:text-5xl">The TOSS Advantage</h2>
      <p class="mx-auto max-w-2xl text-lg text-gray-600">Discover what sets us apart from every other dispatch service on the market.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {advantages.map((a, i) => (
        <div class="flex gap-5 rounded-2xl bg-white p-6 shadow-sm border border-gray-100">
          <div class="shrink-0">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-orange-500 text-white font-black text-sm">
              {String(i + 1).padStart(2, '0')}
            </div>
          </div>
          <div>
            <h3 class="mb-2 font-bold text-gray-900">{a.title}</h3>
            <p class="text-sm leading-relaxed text-gray-500">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
