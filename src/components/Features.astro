---

<section id="about" class="py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 text-center">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-orange-400"
      >
        Why Choose TOSS
      </p>
      <h2 class="mb-4 text-4xl font-black text-white sm:text-5xl">
        Built for Owner-Operators
        <br />
        <span class="text-slate-400">Who Want to Earn More</span>
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-400">
        We're not just a dispatch service. We're a full back-office partner
        dedicated to growing your bottom line.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature, i) => (
          <div class="flex gap-4">
            <div class="shrink-0">
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-orange-500/10 border border-orange-500/20">
                <svg
                  class="h-6 w-6 text-orange-400"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d={feature.icon}
                  />
                </svg>
              </div>
            </div>
            <div>
              <h3 class="mb-2 text-base font-bold text-white">
                {feature.title}
              </h3>
              <p class="text-sm leading-relaxed text-slate-400">{feature.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
