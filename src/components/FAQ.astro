---
const faqs = [
  {
    q: 'How does Trucking One Stop Shop help trucking companies save time?',
    a: 'We remove the two biggest time drains in trucking: searching for loads and handling paperwork. Your dispatcher sources and books loads, negotiates rates, handles check calls, processes documents, and manages broker communication — so you can focus entirely on driving.',
  },
  {
    q: 'What types of loads can TOSS manage?',
    a: 'We dispatch Dry Van, Reefer, Flatbed, Step Deck, Hotshot, Box Truck, Conestoga, and Power Only loads. Our dispatchers specialize in your specific truck type and build lane expertise so you get better loads over time.',
  },
  {
    q: 'How much does it cost to use TOSS services?',
    a: 'Pricing starts from just 5% of the gross load value for most truck types (7% for Hotshot). There are no setup fees, no monthly minimums, and no long-term contracts. We also offer promotional rates for new drivers — contact us to learn more.',
  },
  {
    q: 'Can TOSS improve my profitability as a truck driver?',
    a: 'Yes — and measurably. Our carriers typically see a 15-30% increase in gross revenue within the first 90 days. We achieve this through aggressive rate negotiation, eliminating empty miles, securing consistent backhaul loads, and reducing the hours you spend on administrative work.',
  },
];
---

<section id="faq" class="bg-white py-24">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">FAQ</p>
      <h2 class="mb-3 text-4xl font-black text-gray-900 sm:text-5xl">Questions? We have answers</h2>
      <a href="#setup" class="text-sm font-semibold text-orange-500 hover:underline">Ask a question →</a>
    </div>

    <div class="divide-y divide-gray-200 border-y border-gray-200">
      {faqs.map((faq) => (
        <details class="group">
          <summary class="flex cursor-pointer list-none items-start justify-between py-5 pr-2">
            <span class="pr-4 text-base font-bold text-gray-900">{faq.q}</span>
            <span class="mt-1 shrink-0 text-gray-400 transition-transform duration-200 group-open:rotate-45">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
              </svg>
            </span>
          </summary>
          <div class="pb-5 pr-8">
            <p class="text-base leading-relaxed text-gray-600">{faq.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
