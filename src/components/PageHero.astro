---
interface Props {
  title: string;
  subtitle?: string;
  description?: string;
}
const { title, subtitle, description } = Astro.props;
---

<section class="border-b border-gray-200 bg-gray-50 pb-14 pt-32">
  <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
    <h1 class="mb-3 text-5xl font-black text-gray-900 sm:text-6xl">{title}</h1>
    {subtitle && (
      <p class="mb-4 text-xl font-semibold text-orange-500">{subtitle}</p>
    )}
    {description && (
      <p class="mx-auto max-w-2xl text-lg leading-relaxed text-gray-600">{description}</p>
    )}
  </div>
</section>
