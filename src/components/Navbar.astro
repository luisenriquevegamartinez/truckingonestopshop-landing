---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Trucks', href: '#trucks' },
  { label: 'Owner-operators', href: '#about' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Contact Us', href: '#setup' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-100 bg-white shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center shrink-0">
      <img
        src="https://cdn.prod.website-files.com/68dc088d78e9540e9d74949f/68e44fdbac696de8a9d35a28_Con%20slogan.svg"
        alt="Trucking One Stop Shop"
        class="h-10 w-auto"
        loading="eager"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <span style="display:none" class="items-center gap-1 font-black text-gray-900 text-lg">
        <span class="text-orange-500">TOSS</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 lg:flex">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium text-gray-600 transition-colors hover:text-orange-500">
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-4 md:flex">
      <a href="tel:+18887771839" class="flex items-center gap-1.5 text-sm font-bold text-gray-800 hover:text-orange-500 transition-colors">
        <svg class="h-4 w-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
        </svg>
        +1 888-777-1839
      </a>
      <a href="#setup" class="rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-bold text-white transition-all hover:bg-orange-600 hover:shadow-md">
        Get a free setup
      </a>
    </div>

    <button id="nav-toggle" class="flex flex-col gap-1.5 p-1 lg:hidden" aria-label="Menu">
      <span class="block h-0.5 w-6 bg-gray-700"></span>
      <span class="block h-0.5 w-6 bg-gray-700"></span>
      <span class="block h-0.5 w-6 bg-gray-700"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white lg:hidden">
    <div class="flex flex-col gap-4 px-4 py-5">
      {navLinks.map((link) => (
        <a href={link.href} class="text-sm font-medium text-gray-600 hover:text-orange-500">{link.label}</a>
      ))}
      <div class="border-t border-gray-100 pt-4 space-y-3">
        <a href="tel:+18887771839" class="block text-sm font-bold text-gray-800">+1 888-777-1839</a>
        <a href="#setup" class="block w-full rounded-lg bg-orange-500 px-5 py-3 text-center text-sm font-bold text-white">Get a free setup</a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.getElementById('mobile-menu')?.querySelectorAll('a').forEach(l => l.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.add('hidden');
  }));
</script>
