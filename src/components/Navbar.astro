---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const isActive = (href: string) => {
  const clean = href.replace(/\/$/, '') || '/';
  if (clean === '/') return currentPath === '/';
  return currentPath === clean || currentPath.startsWith(clean + '/');
};

const activeClass =
  'bg-orange-500 text-white text-sm font-semibold px-3 py-1.5 rounded-sm';
const inactiveClass =
  'text-sm font-medium text-gray-600 transition-colors hover:text-gray-900 px-1 py-1.5';

const services = [
  { label: 'Dispatching — Trucking Services', href: '/#services' },
  { label: 'Rate Negotiation', href: '/#services' },
  { label: 'Trucking Accounting', href: '/#services' },
  { label: 'Document Management', href: '/#services' },
  { label: 'DOT Compliance', href: '/#services' },
  { label: 'Freight Factoring', href: '/#services' },
  { label: 'Company Formation Services', href: '/#services' },
];

const trucks = [
  { label: 'Dry Van Dispatch', href: '/#trucks' },
  { label: 'Flatbed Dispatch', href: '/#trucks' },
  { label: 'Reefer Dispatch', href: '/#trucks' },
  { label: 'Step Deck Dispatch', href: '/#trucks' },
  { label: 'Hotshot Dispatch', href: '/#trucks' },
  { label: 'Conestoga Dispatch', href: '/#trucks' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'How to Start', href: '/contact-us' },
];

const topLinks = [
  { label: 'Owner-operators', href: '/owner-operators' },
  { label: 'FAQ', href: '/faq' },
  { label: 'Contact Us', href: '/contact-us' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-100 bg-white shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center">
      <img
        src="https://cdn.prod.website-files.com/68dc088d78e9540e9d74949f/68e44fdbac696de8a9d35a28_Con%20slogan.svg"
        alt="Trucking One Stop Shop"
        class="h-10 w-auto"
        loading="eager"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex';"
      />
      <span style="display:none" class="items-center font-black text-lg text-gray-900">
        <span class="text-orange-500">TOSS</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex">

      <!-- Services dropdown -->
      <div class="group relative">
        <button
          class={`flex items-center gap-1 ${isActive('/services') ? activeClass : inactiveClass}`}
        >
          Services
          <svg class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
          </svg>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 w-64 rounded-xl border border-gray-100
                 bg-white p-2 opacity-0 shadow-lg transition-all duration-150
                 group-hover:visible group-hover:opacity-100"
        >
          {services.map((s) => (
            <a
              href={s.href}
              class="block rounded-lg px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600"
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Trucks dropdown -->
      <div class="group relative">
        <button
          class={`flex items-center gap-1 ${isActive('/trucks') ? activeClass : inactiveClass}`}
        >
          Trucks
          <svg class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
          </svg>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 w-56 rounded-xl border border-gray-100
                 bg-white p-2 opacity-0 shadow-lg transition-all duration-150
                 group-hover:visible group-hover:opacity-100"
        >
          {trucks.map((t) => (
            <a
              href={t.href}
              class="block rounded-lg px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600"
            >
              {t.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Simple links -->
      {topLinks.map((link) => (
        <a href={link.href} class={isActive(link.href) ? activeClass : inactiveClass}>
          {link.label}
        </a>
      ))}

      <!-- Company dropdown -->
      <div class="group relative">
        <button
          class={`flex items-center gap-1 ${isActive('/about') ? activeClass : inactiveClass}`}
        >
          Company
          <svg class="h-3.5 w-3.5 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m19 9-7 7-7-7"/>
          </svg>
        </button>
        <div
          class="invisible absolute right-0 top-full z-50 w-44 rounded-xl border border-gray-100
                 bg-white p-2 opacity-0 shadow-lg transition-all duration-150
                 group-hover:visible group-hover:opacity-100"
        >
          {company.map((c) => (
            <a
              href={c.href}
              class="block rounded-lg px-4 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600"
            >
              {c.label}
            </a>
          ))}
        </div>
      </div>

    </nav>

    <!-- Phone + CTA -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href="tel:+18887771839"
        class="flex items-center gap-1.5 text-sm font-bold text-gray-800 transition-colors hover:text-orange-500"
      >
        <svg class="h-4 w-4 text-orange-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
        </svg>
        +1 888-777-1839
      </a>
      <a
        href="/contact-us"
        class="rounded-sm bg-orange-500 px-5 py-2.5 text-sm font-bold text-white transition-all hover:bg-orange-600 hover:shadow-md"
      >
        Get a free setup
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button id="nav-toggle" class="flex flex-col gap-1.5 p-1 lg:hidden" aria-label="Menu">
      <span class="block h-0.5 w-6 bg-gray-700"></span>
      <span class="block h-0.5 w-6 bg-gray-700"></span>
      <span class="block h-0.5 w-6 bg-gray-700"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-100 bg-white lg:hidden">
    <div class="flex flex-col gap-1 px-4 py-5">
      <p class="mb-1 text-xs font-bold uppercase tracking-wider text-gray-400">Services</p>
      {services.slice(0, 4).map((s) => (
        <a href={s.href} class="rounded px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600">
          {s.label}
        </a>
      ))}
      <div class="my-2 border-t border-gray-100"></div>
      <p class="mb-1 text-xs font-bold uppercase tracking-wider text-gray-400">Trucks</p>
      {trucks.map((t) => (
        <a href={t.href} class="rounded px-3 py-2 text-sm text-gray-700 hover:bg-orange-50 hover:text-orange-600">
          {t.label}
        </a>
      ))}
      <div class="my-2 border-t border-gray-100"></div>
      {[...topLinks, ...company].map((link) => (
        <a
          href={link.href}
          class={`rounded px-3 py-2 text-sm font-medium ${isActive(link.href) ? 'bg-orange-500 text-white' : 'text-gray-700 hover:bg-orange-50 hover:text-orange-600'}`}
        >
          {link.label}
        </a>
      ))}
      <div class="mt-3 border-t border-gray-100 pt-3">
        <a href="tel:+18887771839" class="mb-2 block text-sm font-bold text-gray-800">+1 888-777-1839</a>
        <a href="/contact-us" class="block w-full rounded-sm bg-orange-500 px-5 py-3 text-center text-sm font-bold text-white">
          Get a free setup
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
  document.getElementById('mobile-menu')?.querySelectorAll('a').forEach((l) =>
    l.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.add('hidden');
    })
  );
</script>
