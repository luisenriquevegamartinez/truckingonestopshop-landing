---
const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'Trucks', href: '#trucks' },
  { label: 'About Us', href: '#about' },
  { label: 'Contact', href: '#contact' },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-slate-800/60 bg-slate-900/95 backdrop-blur-md"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img
        src="https://cdn.prod.website-files.com/68dc088d78e9540e9d74949f/68e44fdbac696de8a9d35a28_Con%20slogan.svg"
        alt="Trucking One Stop Shop"
        class="h-10 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-slate-300 transition-colors hover:text-orange-400"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Phone + CTA -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href="tel:+18887771839"
        class="flex items-center gap-2 text-sm font-medium text-slate-300 transition-colors hover:text-white"
      >
        <svg
          class="h-4 w-4 text-orange-400"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
          ></path>
        </svg>
        +1 888-777-1839
      </a>
      <a
        href="#contact"
        class="rounded-lg bg-orange-500 px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-orange-500/20"
      >
        Get Free Setup
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="nav-toggle"
      class="flex flex-col items-center justify-center gap-1.5 p-1 md:hidden"
      aria-label="Toggle navigation menu"
    >
      <span class="block h-0.5 w-6 bg-white transition-all" id="bar1"></span>
      <span class="block h-0.5 w-6 bg-white transition-all" id="bar2"></span>
      <span class="block h-0.5 w-6 bg-white transition-all" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-slate-800 bg-slate-900 md:hidden"
  >
    <div class="flex flex-col gap-4 px-4 py-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-slate-300 hover:text-orange-400"
          >
            {link.label}
          </a>
        ))
      }
      <div class="border-t border-slate-800 pt-4">
        <a
          href="tel:+18887771839"
          class="mb-3 flex items-center gap-2 text-sm font-medium text-slate-300"
        >
          +1 888-777-1839
        </a>
        <a
          href="#contact"
          class="block w-full rounded-lg bg-orange-500 px-5 py-3 text-center text-sm font-semibold text-white"
        >
          Get Free Setup
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu when a link is clicked
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
    });
  });
</script>
