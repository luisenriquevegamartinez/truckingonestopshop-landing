---
const services = [
  {
    icon: '/images/icon-dispatch.svg',
    title: 'Dispatching — Trucking Services',
    desc: 'Your dedicated dispatcher handles load finding, rate negotiation, and broker communication so you can focus on driving.',
    badge: 'SPECIAL OFFER',
    badgeColor: 'bg-orange-500 text-white',
    promo: 'From 5% of gross',
    promoColor: 'text-orange-500 font-bold',
  },
  {
    icon: '/images/icon-document.svg',
    title: 'Document Dispatch Services',
    desc: 'We handle all your dispatch paperwork — rate confirmations, BOLs, check calls, and delivery receipts.',
    badge: 'NEW',
    badgeColor: 'bg-blue-500 text-white',
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-rate.svg',
    title: 'Trucking Paperwork Services',
    desc: 'End-to-end document management so your operations stay organized and compliant at all times.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-rate.svg',
    title: 'Freight Rate Negotiation Services',
    desc: 'Our experienced dispatchers negotiate aggressively to secure the best possible rates on every load.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-dot.svg',
    title: 'DOT Compliance Services',
    desc: 'Stay fully compliant with proactive permit renewals, DOT filings, and regulatory tracking.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-accounting.svg',
    title: 'Truckers Accounting',
    desc: 'Professional bookkeeping, invoicing, and earnings reports tailored for owner-operators and small fleets.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-factoring.svg',
    title: 'Freight Factoring',
    desc: 'Stop waiting 30-60 days for broker payments. Our factoring partnerships get cash in your account within 24 hours.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
  {
    icon: '/images/icon-dispatch.svg',
    title: 'Company Formation Services',
    desc: 'LLC setup, EIN registration, and operating authority — we help you get your carrier business legally established.',
    badge: null,
    badgeColor: null,
    promo: null,
    promoColor: null,
  },
];
---

<section id="services" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-4 text-center">
      <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-orange-500">Our Services</p>
      <h2 class="mb-4 text-4xl font-black text-gray-900 sm:text-5xl">Discover our services</h2>
      <p class="mx-auto max-w-2xl text-lg text-gray-600">
        Negotiating dispatch rates and drowning in paperwork can be exhausting. Let us handle it while you drive and earn.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((s) => (
        <div class="group relative flex flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:border-orange-200 hover:shadow-md">
          {/* Badges */}
          {s.badge && (
            <span class={`absolute right-4 top-4 rounded-full px-2.5 py-0.5 text-xs font-bold ${s.badgeColor}`}>
              {s.badge}
            </span>
          )}

          {/* Icon */}
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-xl bg-orange-50 p-3">
            <img src={s.icon} alt={s.title} class="h-8 w-8 object-contain" loading="lazy"
              onerror="this.style.display='none'" />
          </div>

          {s.promo && (
            <p class={`mb-1 text-sm ${s.promoColor}`}>{s.promo}</p>
          )}

          <h3 class="mb-2 text-base font-bold text-gray-900">{s.title}</h3>
          <p class="mb-4 flex-1 text-sm leading-relaxed text-gray-500">{s.desc}</p>

          <a href="#setup" class="mt-auto inline-flex items-center gap-1 text-sm font-semibold text-orange-500 hover:text-orange-600">
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
