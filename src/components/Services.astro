---

<section id="services" class="bg-white py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-orange-500">
        What We Do
      </p>
      <h2 class="mb-4 text-4xl font-black text-gray-900 sm:text-5xl">
        Everything Your Trucking Business Needs
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-gray-600">
        From finding loads to handling your books — we take care of the back office
        so you can stay on the road and keep earning.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:border-orange-200 hover:shadow-md">
            <!-- Icon -->
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-orange-50">
              <svg
                class="h-6 w-6 text-orange-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d={service.iconPath} />
              </svg>
            </div>

            <!-- Badge -->
            <span class="mb-3 inline-block rounded-full bg-orange-50 px-2.5 py-0.5 text-xs font-semibold text-orange-600">
              {service.badge}
            </span>

            <h3 class="mb-2 text-base font-bold text-gray-900">{service.title}</h3>
            <p class="text-sm leading-relaxed text-gray-500">{service.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
