const colorMap: Record<string, string> = {
  orange: 'bg-orange-500/15 text-orange-400 border-orange-500/20',
  green: 'bg-green-500/15 text-green-400 border-green-500/20',
  blue: 'bg-blue-500/15 text-blue-400 border-blue-500/20',
  purple: 'bg-purple-500/15 text-purple-400 border-purple-500/20',
  yellow: 'bg-yellow-500/15 text-yellow-400 border-yellow-500/20',
  teal: 'bg-teal-500/15 text-teal-400 border-teal-500/20',
  indigo: 'bg-indigo-500/15 text-indigo-400 border-indigo-500/20',
  rose: 'bg-rose-500/15 text-rose-400 border-rose-500/20',
};

const badgeMap: Record<string, string> = {
  orange: 'bg-orange-500/10 text-orange-300 border-orange-500/20',
  green: 'bg-green-500/10 text-green-300 border-green-500/20',
  blue: 'bg-blue-500/10 text-blue-300 border-blue-500/20',
  purple: 'bg-purple-500/10 text-purple-300 border-purple-500/20',
  yellow: 'bg-yellow-500/10 text-yellow-300 border-yellow-500/20',
  teal: 'bg-teal-500/10 text-teal-300 border-teal-500/20',
  indigo: 'bg-indigo-500/10 text-indigo-300 border-indigo-500/20',
  rose: 'bg-rose-500/10 text-rose-300 border-rose-500/20',
};
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-16 text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-orange-400">
        What We Do
      </p>
      <h2 class="mb-4 text-4xl font-black text-white sm:text-5xl">
        Everything Your Trucking Business Needs
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-slate-400">
        From finding loads to handling your books — we take care of the back office
        so you can stay on the road and keep earning.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        services.map((service) => (
          <div class="group rounded-2xl border border-slate-700/50 bg-slate-800/40 p-6 transition-all hover:border-slate-600 hover:bg-slate-800/70">
            <!-- Icon -->
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center rounded-xl border ${colorMap[service.color]}`}
            >
              <svg
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={service.icon}
                />
              </svg>
            </div>

            <!-- Badge -->
            <span
              class={`mb-3 inline-block rounded-full border px-2.5 py-0.5 text-xs font-medium ${badgeMap[service.color]}`}
            >
              {service.badge}
            </span>

            <h3 class="mb-2 text-base font-bold text-white">{service.title}</h3>
            <p class="text-sm leading-relaxed text-slate-400">{service.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
