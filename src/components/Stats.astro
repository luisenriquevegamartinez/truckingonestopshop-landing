---
const stats = [
  { value: '10+', label: 'Years of Experience' },
  { value: '500+', label: 'Carriers Served' },
  { value: '$7.5k', label: 'Avg Gross per Load' },
  { value: '24/7', label: 'Dispatcher Support' },
];
---

<section class="border-y border-gray-200 bg-gray-50 py-14">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-4">
      {
        stats.map((stat, i) => (
          <div class={`text-center ${i < stats.length - 1 ? 'lg:border-r lg:border-gray-200' : ''}`}>
            <p class="text-4xl font-black text-orange-500 lg:text-5xl">{stat.value}</p>
            <p class="mt-2 text-sm font-medium text-gray-500">{stat.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
